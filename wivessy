<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HAPPY BIRTHDAY WIVESSY 💚</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #fff5f8;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
            animation: fadeIn 2s;
        }

        @keyframes fadeIn {
            from { opacity: 0; }
            to { opacity: 1; }
        }

        /* Thulo Title ko styling */
        .main-heading {
            margin-top: 40px;
            font-size: 3.5rem; /* Ekdam thulo size */
            color: #ff3385;    /* Pink color */
            font-weight: 900;
            text-align: center;
            padding: 0 20px;
            line-height: 1.2;
        }

        .green-heart {
            font-size: 4rem;
            display: block;
            margin-top: 10px;
        }

        .gallery {
            width: 90%;
            max-width: 400px;
            margin: 30px 0;
        }

        .gallery img {
            width: 100%;
            height: auto;
            border-radius: 25px;
            border: 6px solid white;
            box-shadow: 0 8px 15px rgba(0,0,0,0.1);
            margin-bottom: 25px;
            display: block;
        }

        .wish-container {
            padding: 20px;
            text-align: center;
            max-width: 85%;
            background: white; /* Text ko background light white banako */
            border-radius: 20px;
            margin-bottom: 50px;
            box-shadow: 0 4px 10px rgba(0,0,0,0.05);
        }

        .sub-text {
            font-size: 1.8rem;
            color: #ff3385;
            font-weight: 600;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="main-heading">
        HAPPY BIRTHDAY WIVESSY
        <span class="green-heart">💚</span>
    </div>

    <div class="wivessy">
        <img src="images/1photo.jpeg" alt="luv">
        <img src="images/2photo.jpeg" alt="luv">
        <img src="images/3photo.png" alt="luv">
        <img src="images/4photo.png" alt="luv">
    </div>

    <div class="wish-container">
        <div class="sub-text">
            Happy Birthday wivessy luv u always and won't leave you and hope you stay by my side just the same and call you my wife Have the best birthday ever ! 💚😊💫🌺
        </div>
    </div>

</body>
</html>
