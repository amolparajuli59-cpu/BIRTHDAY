<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HAPPY BIRTHDAY WIVESSY 💚</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #fff5f8;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }

        .main-heading {
            margin-top: 40px;
            font-size: 2.8rem;
            color: #ff3385;
            font-weight: 900;
            text-align: center;
            line-height: 1.2;
        }

        .green-heart {
            font-size: 3.5rem;
            display: block;
            margin-top: 10px;
        }

        /* This makes the photos side-by-side and same size */
        .gallery {
            display: grid;
            grid-template-columns: repeat(2, 1fr); /* 2 photos per row */
            gap: 15px; /* Space between photos */
            width: 90%;
            max-width: 500px;
            margin: 30px 0;
        }

        .gallery img {
            width: 100%;
            height: 200px; /* Forces all photos to this height */
            object-fit: cover; /* Crops them perfectly so they don't look squeezed */
            border-radius: 15px;
            border: 4px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .wish-container {
            padding: 25px;
            text-align: center;
            max-width: 85%;
            margin-bottom: 50px;
        }

        .sub-text {
            font-size: 1.8rem;
            color: #ff3385;
            font-weight: bold;
            line-height: 1.4;
        }
    </style>
</head>
<body>

    <div class="main-heading">
        HAPPY BIRTHDAY WIVESSY
        <span class="green-heart">💚</span>
    </div>

    <div class="gallery">
        <img src="1photo.jpeg" alt="luv">
        <img src="2photo.jpeg" alt="luv">
        <img src="3photo.png" alt="luv">
        <img src="4photo.png" alt="luv">
    </div>

    <div class="wish-container">
        <div class="sub-text">
            Happy Birthday wivessy luv u always and won't leave you and hope you stay by my side just the same and call you my wife Have the best birthday ever ! 💚😊💫🌺
        </div>
    </div>

</body>
</html>
