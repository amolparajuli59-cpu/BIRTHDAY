<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>HAPPY BIRTHDAY WIVESSY 💚</title>
    <style>
        body {
            margin: 0;
            padding: 0;
            background-color: #fff5f8;
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
            display: flex;
            flex-direction: column;
            align-items: center;
            overflow-x: hidden;
        }

        .main-heading {
            margin-top: 30px;
            font-size: 2.5rem;
            color: #ff3385;
            font-weight: 900;
            text-align: center;
        }

        .green-heart { font-size: 3rem; display: block; }

        .play-btn {
            background-color: #ff3385;
            color: white;
            border: none;
            padding: 12px 25px;
            border-radius: 25px;
            font-weight: bold;
            margin: 15px 0;
            cursor: pointer;
            box-shadow: 0 4px 10px rgba(255, 51, 133, 0.3);
            font-size: 1.2rem;
        }

        .main-layout {
            display: flex;
            align-items: center;
            justify-content: center;
            width: 98%;
            max-width: 900px;
            margin: 20px 0;
            gap: 10px;
        }

        .side-video {
            flex: 1;
            height: 420px;
            object-fit: cover;
            border-radius: 15px;
            border: 4px solid white;
            box-shadow: 0 5px 15px rgba(0,0,0,0.1);
        }

        .photo-grid {
            display: grid;
            grid-template-columns: repeat(2, 1fr);
            gap: 10px;
            flex: 2;
        }

        .photo-grid img {
            width: 100%;
            height: 200px;
            object-fit: cover;
            border-radius: 15px;
            border: 4px solid white;
        }

        .wish-container {
            padding: 25px;
            text-align: center;
            max-width: 85%;
            margin-bottom: 50px;
        }

        .sub-text {
            font-size: 1.8rem;
            color: #ff3385;
            font-weight: bold;
            line-height: 1.4;
        }

        @media (max-width: 600px) {
            .main-layout { flex-direction: column; }
            .side-video { width: 100%; height: 300px; }
        }
    </style>
</head>
<body>

    <div class="main-heading">
        HAPPY BIRTHDAY WIVESSY
        <span class="green-heart">💚</span>
    </div>

    <button class="play-btn" onclick="playMusic()">Surprise! Tap Here 🎵</button>

    <div class="main-layout">
        <video class="side-video" src="1video.mp4" autoplay muted loop playsinline></video>

        <div class="photo-grid">
            <img src="1photo.jpeg" alt="luv">
            <img src="2photo.jpeg" alt="luv">
            <img src="3photo.png" alt="luv">
            <img src="4photo.png" alt="luv">
        </div>

        <video id="soundVideo" class="side-video" src="2video.mp4" loop playsinline></video>
    </div>

    <div class="wish-container">
        <div class="sub-text">
            Happy Birthday wivessy luv u always and won't leave you and hope you stay by my side just the same and call you my wife Have the best birthday ever ! 💚😊💫🌺
        </div>
    </div>

    <script>
        function playMusic() {
            var vid = document.getElementById("soundVideo");
            vid.play();
            document.querySelector('.play-btn').style.display = 'none';
        }
    </script>

</body>
</html>
